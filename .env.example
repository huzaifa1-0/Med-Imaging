# ── MedFlow Imaging Microservice — Environment Variables ──

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (MSSQL via pyodbc)
DATABASE_URL=mssql+pyodbc://sa:YourPassword@localhost:1433/MedFlowDB?driver=ODBC+Driver+17+for+SQL+Server

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=medflow-imaging-bucket
